# Memdot local example environment.
# Copy to .env for local overrides. Never commit real credentials.
# Phase 1: scaffold only — no production services are configured here.

MEMDOT_ENV=development
MEMDOT_LOG_LEVEL=info

# Service bind defaults (health skeletons)
CORE_HOST=0.0.0.0
CORE_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8100
MODEL_ROUTER_HOST=0.0.0.0
MODEL_ROUTER_PORT=8200
WORKERS_HEALTH_HOST=0.0.0.0
WORKERS_HEALTH_PORT=8300

# Telemetry export is off by default for self-host (ADR-0011).
MEMDOT_TELEMETRY_EXPORT=false

# Tex remains disabled until an operator explicitly enables it.
MEMDOT_TEX_ENABLED=false
