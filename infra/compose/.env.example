# Memdot Compose — non-secret configuration placeholders only.
# Run: bash infra/compose/scripts/materialize_local_secrets.sh
# Secret material lives in ignored infra/compose/secrets/*.env

COMPOSE_PROJECT_NAME=memdot
MEMDOT_PUBLIC_HOST=localhost
MEMDOT_HTTP_PORT=8080
MEMDOT_HTTPS_PORT=8443
MEMDOT_PUBLIC_URL=https://localhost:8443
HATCHET_COOKIE_DOMAIN=localhost
HATCHET_SERVER_URL=http://127.0.0.1:18080
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
