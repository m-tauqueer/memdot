{
  "title": "Memdot Data Stores",
  "uid": "memdot-data-stores",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["memdot", "ops", "postgres", "seaweedfs", "content-free"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PostgreSQL availability",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_up or up{job=~\".*postgres.*\"} or vector(0)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SeaweedFS availability",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\".*seaweed.*\"} or vector(0)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OpenBao availability",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\".*openbao.*|.*vault.*\"} or vector(0)"
        }
      ]
    }
  ]
}
