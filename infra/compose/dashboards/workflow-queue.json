{
  "title": "Memdot Workflow Queue",
  "uid": "memdot-workflow-queue",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["memdot", "ops", "hatchet", "content-free"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Workflow queue depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "hatchet_queue_depth or vector(0)",
          "legendFormat": "depth"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Workflow queue age",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "hatchet_queue_oldest_age_seconds or vector(0)",
          "legendFormat": "age_seconds"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Terminal workflow failures",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(hatchet_workflow_failed_total[1h]) or vector(0)"
        }
      ]
    }
  ]
}
