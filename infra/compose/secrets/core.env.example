CORE_ENV=self_host
CORE_DATABASE_URL=postgres://memdot_core:REPLACE_WITH_OPERATOR_SECRET@postgres:5432/memdot
MEMDOT_MIGRATION_DATABASE_URL=postgres://memdot_migrate:REPLACE_WITH_OPERATOR_SECRET@postgres:5432/memdot
MEMDOT_BOOTSTRAP_DATABASE_URL=postgres://memdot:REPLACE_WITH_OPERATOR_SECRET@postgres:5432/memdot
CORE_OBJECT_STORE_ENDPOINT=http://seaweedfs:8333
CORE_OBJECT_STORE_ACCESS_KEY=REPLACE_WITH_OPERATOR_SECRET
CORE_OBJECT_STORE_SECRET_KEY=REPLACE_WITH_OPERATOR_SECRET
CORE_OIDC_ISSUER=https://localhost:8443/realms/memdot
CORE_OIDC_AUDIENCE=memdot-core
CORE_ALLOWED_ORIGINS=https://localhost:8443
CORE_OPENBAO_ADDR=http://openbao:8200
CORE_OPENBAO_TRANSIT_TOKEN_FILE=/run/secrets/openbao_transit_token
CORE_TELEMETRY_EXPORT=off
CORE_OTEL_EXPORTER_OTLP_ENDPOINT=
CORE_SESSION_SIGNING_PEPPER=REPLACE_WITH_OPERATOR_SECRET
CORE_TENANT_CONTEXT_SIGNING_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
CORE_OIDC_CLIENT_ID=memdot-core
CORE_OIDC_CLIENT_SECRET=REPLACE_WITH_OPERATOR_SECRET
CORE_OIDC_REDIRECT_URI=https://localhost:8443/api/v1/auth/oidc/callback
