CORE_ENV=self_host
CORE_DATABASE_URL=postgres://memdot:REPLACE_WITH_OPERATOR_SECRET@postgres:5432/memdot
CORE_OBJECT_STORE_ENDPOINT=http://seaweedfs:8333
CORE_OBJECT_STORE_ACCESS_KEY=REPLACE_WITH_OPERATOR_SECRET
CORE_OBJECT_STORE_SECRET_KEY=REPLACE_WITH_OPERATOR_SECRET
CORE_OIDC_ISSUER=https://localhost:8443/realms/memdot
CORE_OIDC_AUDIENCE=memdot-core
CORE_ALLOWED_ORIGINS=https://localhost:8443
CORE_OPENBAO_ADDR=http://openbao:8200
CORE_OPENBAO_TRANSIT_TOKEN_FILE=/run/secrets/openbao_transit_token
CORE_TELEMETRY_EXPORT=off
CORE_OTEL_EXPORTER_OTLP_ENDPOINT=
