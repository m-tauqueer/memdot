{
  "components": {
    "schemas": {
      "AttestationBody": {
        "properties": {
          "confirmed": {
            "title": "Confirmed",
            "type": "boolean"
          }
        },
        "required": [
          "confirmed"
        ],
        "title": "AttestationBody",
        "type": "object"
      },
      "CompleteUploadBody": {
        "properties": {
          "upload_id": {
            "format": "uuid",
            "title": "Upload Id",
            "type": "string"
          }
        },
        "required": [
          "upload_id"
        ],
        "title": "CompleteUploadBody",
        "type": "object"
      },
      "CreateSourceBody": {
        "properties": {
          "space_id": {
            "format": "uuid",
            "title": "Space Id",
            "type": "string"
          },
          "title": {
            "maxLength": 512,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "space_id",
          "title"
        ],
        "title": "CreateSourceBody",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ReprocessBody": {
        "properties": {
          "revision_id": {
            "format": "uuid",
            "title": "Revision Id",
            "type": "string"
          },
          "shadow": {
            "default": false,
            "title": "Shadow",
            "type": "boolean"
          }
        },
        "required": [
          "revision_id"
        ],
        "title": "ReprocessBody",
        "type": "object"
      },
      "UploadIntentBody": {
        "properties": {
          "byte_count": {
            "minimum": 1.0,
            "title": "Byte Count",
            "type": "integer"
          },
          "content_type": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Content Type",
            "type": "string"
          },
          "filename": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Filename",
            "type": "string"
          },
          "sha256": {
            "maxLength": 64,
            "minLength": 64,
            "title": "Sha256",
            "type": "string"
          }
        },
        "required": [
          "filename",
          "content_type",
          "byte_count",
          "sha256"
        ],
        "title": "UploadIntentBody",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
