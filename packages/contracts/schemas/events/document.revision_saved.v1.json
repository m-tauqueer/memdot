{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.memdot.app/events/document.revision_saved.v1.json",
  "title": "document.revision_saved",
  "type": "object",
  "required": ["document_id", "revision_id", "space_id", "content_sha256"],
  "properties": {
    "document_id": { "type": "string", "format": "uuid" },
    "revision_id": { "type": "string", "format": "uuid" },
    "space_id": { "type": "string", "format": "uuid" },
    "base_revision_id": { "type": "string", "format": "uuid" },
    "content_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
    "author_actor_id": { "type": "string", "format": "uuid" },
    "proposal_id": { "type": "string", "format": "uuid" }
  },
  "additionalProperties": false
}
