{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.memdot.app/provider-port-health/v1.json",
  "title": "Provider Port Health",
  "description": "Health response contract for memory provider ports.",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "unavailable"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
